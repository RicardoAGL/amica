# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/out/

# parcel
/.parcel-cache/
/dist/

# production
/build

# misc
.DS_Store
*.pem

# local env overrides (contain secrets — never commit)
*.env.local
local-config.env

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

working/*

# local tooling (Claude Code / CoderLM indexes)
.claude/
.coderlm/
.infisical.json

# large binary assets (VRM models, vtuber items)
public/vrm/
vtuber_items/

# session notes
docs/phase-state.md
!working/.gitkeep

# Sentry Config File
.env.sentry-build-plugin
